<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/surface_variant" />

    <TextView
        android:id="@+id/tv_video_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        tools:text="Video Title" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ll_start_download"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="Start Download"
        android:textColor="@color/text_primary"
        app:icon="@drawable/ic_download"
        app:iconSize="24dp"
        app:iconTint="@color/text_secondary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ll_pause_download"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="Pause Download"
        android:textColor="@color/text_primary"
        app:icon="@drawable/exo_icon_pause"
        app:iconSize="24dp"
        app:iconTint="@color/text_secondary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ll_resume_download"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="Resume Download"
        android:textColor="@color/text_primary"
        app:icon="@drawable/exo_controls_play"
        app:iconSize="24dp"
        app:iconTint="@color/text_secondary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ll_delete_download"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="Delete Download"
        android:textColor="@color/primary"
        app:icon="@drawable/ic_delete"
        app:iconSize="24dp"
        app:iconTint="@color/primary" />

</LinearLayout>